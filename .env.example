# ── Anthropic / Claude (côté serveur uniquement) ─────────────────────────────
# Obtenir sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# ── Supabase (côté serveur — service role pour le webhook Stripe) ─────────────
# Obtenir sur : https://app.supabase.com → Settings → API
SUPABASE_URL=https://VOTRE_PROJET.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (côté frontend — anon key, préfixe VITE_ requis) ─────────────────
# Même URL que ci-dessus, clé "anon/public" (pas service_role)
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Clés sur : https://dashboard.stripe.com → Développeurs → Clés API
# Utiliser les clés LIVE (sk_live_...) en production
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_ICI
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_SECRET_ICI

# IDs des prix Stripe (Produits → Tarifs → Copier l'ID)
STRIPE_PRICE_SOLO=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PRO=price_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_STUDIO=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Frontend URL (pour les redirections Stripe) ───────────────────────────────
# En production : votre domaine sans slash final
# En développement : http://localhost:5173
FRONTEND_URL=https://qovee.com
